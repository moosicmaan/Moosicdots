#!/usr/bin/env bash
# =====================================================
# -----------------------------------------------------
# Convert a .csv file of keybinds into configuration
# information for various window managers and
# wayland copositors
# Must be run from Hyprland
#    Jason Bradberry (2026)
# -----------------------------------------------------
# =====================================================

binds_file="$HOME/.config/.settings/hyprbinds.json"
cvs_file="$HOME/.config/.settings/binds.csv"

# Function to communicate extit status
leave() {
    case "$1" in
    0) echo "All went well" ;;
    1)
        echo "Must be run from Hyprland"
        exit 1
        ;;
    3)
        echo "File not found"
        exit 3
        ;;
    *)
        echo "Something bad happened"
        exit 13
        ;;
    esac
}

# Function to map modmask values to strings
map_modmask() {
    case "$1" in
    0) echo "(NONE)" ;;
    1) echo "S" ;;
    4) echo "C" ;;
    5) echo "C-S" ;;
    8) echo "A" ;;
    12) echo "C-A" ;;
    13*) echo "MEH(C-A-S)" ;;
    64) echo "M" ;;
    65) echo "M-S" ;;
    68) echo "M-C" ;;
    72) echo "M-A" ;;
    77) echo "HYPER(M-C-A-S)" ;;
    *) echo "Unknown: $1" ;;
    esac
}

# check that the script is being run from Hyprland, exit if not
[[ "$DESKTOP_SESSION" == "hyprland" || "$DESKTOP_SESSION" == "hyprland-uwsm" ]] || leave 1

# Start with a clean slate and no old files
if [[ -f "$binds_file" ]]; then
    rm "$binds_file"
else
    echo "$binds_file not found"
fi

if [[ -f "$cvs_file" ]]; then
    rm "$cvs_file"
else
    echo "$cvs_file not found"
fi

# Get JSON output from hyprctl
json_output=$(hyprctl binds -j)

# Process JSON: Convert modmask values using a loop
updated_json=$(echo "$json_output" | jq -c '.[]' | while read -r bind; do
    modmask_value=$(echo "$bind" | jq -r '.modmask')
    modmask_str=$(map_modmask "$modmask_value")
    echo "$bind" | jq --arg modmask_str "$modmask_str" '.modmask = $modmask_str'
done | jq -s '.')

# Save to file
echo "$updated_json" >"$binds_file"

# output json file into csv format
jq -r '( .[0] | keys_unsorted ) as $keys
   | ($keys | @csv), ( .[] | [ .[$keys[]] ] | @csv )' "$binds_file" >"$cvs_file"

if [[ -f "$binds_file" ]]; then
    echo "File '$binds_file' has been created successfully."
else
    echo "$binds_file not found"
    leave 3
fi

if [[ -f "$cvs_file" ]]; then
    echo "File '$cvs_file' has been created successfully."
else
    echo "$cvs_file not found"
    leave 3
fi

leave 0
