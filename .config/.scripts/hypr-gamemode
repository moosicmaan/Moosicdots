#!/usr/bin/env bash
# =====================================================
# -----------------------------------------------------
# Turn off Hyprland animations and other effects for gaming
#    Jason Bradberry (2024)
# -----------------------------------------------------
# =====================================================

my_scripts="$HOME/.config/.scripts"
tmpFile="/tmp/gamestatus"

: >>"$tmpFile"
status="$(cat $tmpFile)"

# echo "DEBUG: cat tmpFile = $status"

case "$status" in 1 | true | TRUE) turnOn=0 ;; 0 | false | FALSE) turnOn=1 ;; *) turnOn=1 ;; esac

if [ "$turnOn" -eq 1 ]; then
    hyprctl eval 'hl.config({ animations = { enabled = false } })'
    hyprctl eval 'hl.config({ general = { border_size = 0, gaps_in = 0, gaps_out = 0 } })'
    hyprctl eval 'hl.config({ decoration = { active_opacity = 1.0, inactive_opacity = 1.0, fullscreen_opacity = 1, rounding = 15, blur = { enabled = false }, shadow = { enabled = false } } })'
    hyprctl eval 'hl.monitor({ output = "eDP-1", disabled = true })'
    hyprctl eval 'hl.window_rule({name = "foot override", match = { initial_title = "foot" }, opacity = "1.0 override 1.0 override 1.0 override",})'

    pkill -x awww-daemon 2>/dev/null || true
    pkill -x waybar 2>/dev/null || true
    notify-send -i "nudity-symbolic" "GAME MODE" "ON"
    echo true >$tmpFile
else
    hyprctl eval 'hl.monitor({ output = "eDP-1", mode = "1920x1080@60", disabled = false })'

    awww-daemon &
    "$my_scripts/wb-launch" --init >/dev/null
    hyprctl reload
    notify-send -i "nudity-none-symbolic" "GAME MODE" "OFF"
    echo false >$tmpFile
fi
