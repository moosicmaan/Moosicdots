{
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "max-length": 200,
    "player-icons": {
      "default": "▶ ",
      "mpv": "🎵",
      "spotube": "👠 "
    },
    "status-icons": {
      "paused": "⏸"
    }
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 4
    }
  },
  "hyprland/submap": {
    "format": "✌️ {}",
    "max-length": 18,
    "tooltip": false
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Kitty": "$1",
      "(.*) - Wezterm": "$1"
    },
    "separate-outputs": true,
    "icon": true,
    "spacing": 5,
    "icon-size": 14
  },
  "custom/cliphist": {
    "format": "",
    "on-click": "sleep 0.1 && ~/.config/.scripts/rofi-cliphist",
    // "on-click-right": "sleep 0.1 && ~/.config/.scripts/rofi-cliphist d",
    // "on-click-middle": "sleep 0.1 && ~/.config/.scripts/rofi-cliphist w",
    "tooltip": false
  },
  "custom/updates": {
    "format": "  {}",
    "tooltip-format": "{}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/.scripts/waybar-updates",
    "restart-interval": 60,
    "on-click": "kitty --class dotfiles-floating -e garuda-update",
    // "on-click-right": "~/.config/.settings/software.sh",
    "tooltip": false
  },
  "custom/wallpaper": {
    "format": "",
    "on-click": "~/.config/.scripts/ut-wallpaper select",
    "on-click-right": "~/.config/.scripts/ut-wallpaper random",
    "tooltip": false
  },
  "custom/waybarthemes": {
    "format": "",
    "on-click": "~/.config/.scripts/wb-switch",
    "tooltip": false
  },
  "custom/settings": {
    "format": "",
    // "on-click": "wezterm start --class dotfiles-floating -e ~/.config/.settings/start-settings.sh",
    "tooltip": false
  },
  "custom/keybindings": {
    "format": "",
    "on-click": "~/.config/.scripts/hypr-keybinds",
    "tooltip": false
  },
  "custom/filemanager": {
    "format": "",
    "on-click": "dolphin",
    "tooltip": false
  },
  "custom/browser": {
    "format": "🖧",
    "on-click": "brave",
    "tooltip": false
  },
  "custom/chatgpt": {
    "format": " ",
    "on-click": "brave --app=https://chat.openai.com",
    "tooltip": false
  },
  "custom/calculator": {
    "format": "",
    "on-click": "qalculate-gtk",
    "tooltip": false
  },
  "custom/appmenu": {
    "format": "Apps",
    "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    "on-click-right": "~/.config/.scripts/hypr-keybinds",
    "tooltip": false
  },
  "custom/appmenuicon": {
    "format": "",
    "on-click": "rofi -show drun -replace",
    "on-click-right": "~/.config/.scripts/hypr-keybinds",
    "tooltip": false
  },
  "custom/exit": {
    "format": "",
    "on-click": "wlogout",
    "tooltip": false
  },
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "",
      "unlocked": ""
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "custom/system": {
    "format": "",
    "tooltip": false
  },
  "cpu": {
    "format": "/ C {usage}% ",
    "on-click": "kitty -e btop"
  },
  "memory": {
    "format": "/ M {}% ",
    "on-click": "kitty -e btop"
  },
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "kitty -e btop"
  },
  "hyprland/language": {
    "format": "/ K {short}"
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory",
      "hyprland/language"
    ]
  },
  "group/settings": {
    "orientation": "horizontal",
    "modules": [
      "custom/chatgpt",
      "custom/waybarthemes",
      "custom/wallpaper"
    ]
  },
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/browser",
      "custom/filemanager"
    ]
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "   {signalStrength}%",
    "format-ethernet": "󰈀 {ifname}",
    "format-disconnected": "Disconnected",
    "tooltip-format": "󰈀 {ifname} via {gwaddri}",
    "tooltip-format-wifi": "  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "󰈀 {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "nm-connection-editor"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "   {capacity}%",
    "format-plugged": "  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": [
      " ",
      " ",
      " ",
      " ",
      " "
    ]
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{volume}% {icon} {format_source}",
    "format-bluetooth-muted": "󰂲  {icon} {format_source}",
    "format-muted": "󰝟 {format_source}",
    "format-source": "{volume}% ",
    "format-source-muted": "",
    "format-icons": {
      "headphone": "",
      "hands-free": "󰥎",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": [
        "",
        " ",
        " "
      ]
    },
    "on-click": "pavucontrol"
  },
  "bluetooth": {
    "format": " {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "",
      "deactivated": ""
    },
    "on-click-right": "swaylock -f"
  }
}
