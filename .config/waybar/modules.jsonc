  "sway/scratchpad": {
    "format": "{icon}{count}",
    "show-empty": false,
    "format-icons": [
      "",
      "ΎΜΤ"
    ],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "sway/mode": {
    "format": "ΎΩ╝ {}",
    "max-length": 50
  },
  "sway/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "(.*) - Mozilla Firefox": "ΏθΝΟ $1",
      "(.*) - Brave": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Kitty": "$1",
      "(.*) - Foot": "$1",
      "(.*) - Footclient": "$1",
      "(.*) - Wezterm": "$1",
      "(.*) - Zen": "$1",
      "(.*) - vim": "ΌθΖ $1",
      "(.*) - nvim": "ΌθΖ $1",
      "(.*) - Zen Browser": "$1"
    },
    "all-outputs": true,
    "offscreen-css": true,
    "offscreen-css-text": "(inactive)",
    "icon": true,
    "icon-size": 12
  },
  "hyprland/window": {
    "rewrite": {
      "(.*) - Mozilla Firefox": "ΏθΝΟ $1",
      "(.*) - Brave": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Kitty": "$1",
      "(.*) - Foot": "$1",
      "(.*) - Footclient": "$1",
      "(.*) - Wezterm": "$1",
      "(.*) - Zen": "$1",
      "(.*) - vim": "ΌθΖ $1",
      "(.*) - nvim": "ΌθΖ $1",
      "(.*) - Zen Browser": "$1"
    },
    "separate-outputs": true,
    "max-length": 46,
    "icon": true,
    "spacing": 5,
    "icon-size": 11
  },
  "dwl/window": {
    "format": "{}",
    "icon": true,
    "icon-size": 11,
    "max-length": 50,
    "rewrite": {
      "(.*) - Mozilla Firefox": "ΏθΝΟ $1",
      "(.*) - Brave": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Kitty": "$1",
      "(.*) - Foot": "$1",
      "(.*) - Footclient": "$1",
      "(.*) - Wezterm": "$1",
      "(.*) - Zen": "$1",
      "(.*) - vim": "ΌθΖ $1",
      "(.*) - nvim": "ΌθΖ $1",
      "(.*) - Zen Browser": "$1"
    }
  },
  "custom/cliphist": {
    "format": "ΎΔς",
    "on-click": "sleep 0.1 && ~/.config/.scripts/rofi-cliphist",
    "on-click-right": "sleep 0.1 && ~/.config/.scripts/rofi-cliphist d",
    "on-click-middle": "sleep 0.1 && ~/.config/.scripts/rofi-cliphist w",
    "tooltip": true,
    "tooltip-format": "Clipboard History"
  },
  "custom/appmenu": {
    "format": "ΎΑΧ",
    "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    "on-click-right": "rofi -show drun -replace",
    "tooltip": false
  },
  "custom/launcher": {
    "format": "ΎΣΟ",
    "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    "on-click-right": "~/.config/.scripts/hypr-keybinds",
    "tooltip": false
  },
  "custom/launcherg": {
    "format": "    ",
    "on-click": "exec nwg-drawer -c 7 -is 70 -spacing 23",
    "tooltip": false
  },
  "custom/exit": {
    "format": "ΎΜ╡",
    "on-click": "wlogout",
    "tooltip": true,
    "tooltip-format": "Power Menu"
  },
  "custom/power": {
    "format": "ΎΛΞ",
    "on-click": "wlogout",
    "tooltip": false
  },
  "custom/wallpaper": {
    "format": "ΎΑ╛",
    "on-click": "~/.config/.scripts/ut-wallpaper --select",
    "on-click-right": "~/.config/.scripts/ut-wallpaper --random",
    "tooltip": true,
    "tooltip-format": "Wallpaper Selector"
  },
  "custom/waybarthemes": {
    "format": "≤░Β▒",
    "on-click": "~/.config/.scripts/hypr-barswitch",
    "tooltip": true,
    "tooltip-format": "Status Bar Selector"
  },
  "custom/settings": {
    "format": "ΎΑΥ",
    "on-click": "kitty --class floating -e ~/.config/.scripts/start-settings.sh",
    "tooltip": false
  },
  "custom/keybindings": {
    "format": "ΎΕε",
    "on-click": "~/.config/.scripts/hypr-keybinds",
    "tooltip": true,
    "tooltip-format": "Keybindings and Exec"
  },
  "custom/filemanager": {
    "format": "ΎΒ╝",
    "on-click": "dolphin",
    "tooltip": true,
    "tooltip-format": "File Manager"
  },
  "custom/browser": {
    "format": "Ό╣Η",
    "on-click": "zen-browser",
    "tooltip": true,
    "tooltip-format": "Internet Browser"
  },
  "custom/chatgpt": {
    "format": "≤▒ε╣",
    "on-click": "brave --app=https://chat.openai.com",
    "tooltip": true,
    "tooltip-format": "AI Web App"
  },
  "custom/calculator": {
    "format": "ΎΘυ",
    "on-click": "galculator",
    "tooltip": true,
    "tooltip-format": "Calculator"
  },
  "custom/appmenuicon": {
    "format": "ΎΝΔ",
    "icon-size": 11,
    "on-click": "rofi -show drun -replace",
    "on-click-right": "~/.config/.scripts/hypr-keybinds",
    "tooltip": false
  },
  "custom/system": {
    "format": "ΎΑΥ",
    "tooltip": true,
    "tooltip-format": "System Status"
  },
  "custom/updates": {
    "format": "{} {icon}",
    "return-type": "json",
    "format-icons": {
      // "has-updates": "≤▒Ξ╖",
      "has-updates": "ΎΓτ",
      "updated": "≤░Γς",
      "interval": 7200
    },
    // "escape": true,
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates",
    // "restart-interval": 60,
    // "on-click": "kitty --class floating -e garuda-update"
    "on-click": "kitty --class floating -e ~/.config/.scripts/start-settings.sh"
  },
  "cava": {
    "cava_config": "$XDG_CONFIG_HOME/cava/waybar_raw.conf",
    "input_delay": 2,
    "format-icons": [
      "έΨΒ",
      "έΨΓ",
      "έΨΔ",
      "έΨΕ",
      "έΨΖ",
      "έΨΗ",
      "έΨΘ",
      "έΨΙ"
    ],
    "actions": {
      "on-click-right": "mode"
    }
  },
  "custom/playerctl": {
    "format": "<span>{}</span>",
    "return-type": "json",
    "max-length": 35,
    "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}} ~ {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5,
    "on-scroll-up": "~/.config/.scripts/Volume.sh --inc",
    "on-scroll-down": "~/.config/.scripts/Volume.sh --dec",
    "smooth-scrolling-threshold": 1
  },
  "pulseaudio": {
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{icon} ΎΛΦ {volume}% {format_source}",
    "format-bluetooth-muted": "≤░Γ▓H {icon} ΎΛΦ {format_source}",
    "format-muted": "ΎΣο  {format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "≤░ξΟ",
      "headset": "Ό╣β",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑρ ",
        "ΎΑρ "
      ]
    },
    "random-icons": {
      "off": "<span color=\"#f53c3c\">ΎΒ┤</span> ",
      "on": "ΎΒ┤ "
    },
    "repeat-icons": {
      "on": "ΎΑη "
    },
    "single-icons": {
      "on": "ΎΑη 1 "
    },
    "state-icons": {
      "paused": "ΎΒΝ",
      "playing": "ΎΒΜ"
    },
    "on-scroll-up": "$HOME/.config/.scripts/media-vol --inc",
    "on-scroll-down": "$HOME/.config/.scripts/media-vol --dec",
    "on-click": "$HOME/.config/.scripts/media-ctrl --prv",
    "on-click-middle": "pavucontrol",
    // "on-click-middle": "$HOME/.config/.scripts/media-ctrl --pause",
    "on-click-right": "$HOME/.config/.scripts/media-ctrl --nxt"
    // "on-click-foward": "pavucontrol-qt",
    // "on-click-backward": "pavucontrol-qt"
  },
