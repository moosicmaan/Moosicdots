    "format-linked": "{ifname} (No IP)",
    "family": "ipv4",
    "tooltip-format": "≤░ΙΑ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "ΎΘτ {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "≤░ΙΑ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
