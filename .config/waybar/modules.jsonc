      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "≤░Χ╛",
        "ΎΑρ"
      ],
      "tooltip-format": "{icon} {desc} | {volume}%",
      "ignored-sinks": [
        "Easy Effects Sink"
      ]
    },
    "scroll-step": 5,
    "on-click": "~/.config/.scripts/Volume.sh --toggle",
    "on-click-right": "pavucontrol-qt -t 3",
    "on-scroll-up": "~/.config/.scripts/volume --inc",
    "on-scroll-down": "~/.config/.scripts/volume --dec",
    "tooltip-format": "{icon} {desc} | {volume}%",
    "smooth-scrolling-threshold": 1
  },
  "pulseaudio#microphone_vertical": {
    "format": "{format_source}",
    "format-source": "≤░Ξυ",
    "format-source-muted": "≤░Ξφ",
    "on-click-right": "pavucontrol",
    "on-click": "~/.config/.scripts/Volume.sh --toggle-mic",
    "on-scroll-up": "~/.config/.scripts/Volume.sh --mic-inc",
    "on-scroll-down": "~/.config/.scripts/Volume.sh --mic-dec",
    "max-volume": 100,
    "tooltip": true,
    "tooltip-format": "{source_desc} | {source_volume}%"
  },
  "temperature#vertical": {
    "interval": 10,
    "tooltip": true,
    "hwmon-path": [
      "/sys/class/hwmon/hwmon1/temp1_input",
      "/sys/class/thermal/thermal_zone0/temp"
    ],
    "critical-threshold": 80,
    "format-critical": "{icon}\n{temperatureC}┬░C",
    "format": " {icon}",
    "format-icons": [
      "≤░Ι╕"
    ],
    "on-click-right": "kitty --title nvtop sh -c 'nvtop'"
  },
  "custom/power_vertical": {
    "format": "έΠ╗",
    "exec": "echo ; echo ≤░θκ power // blur",
    "on-click": "~/.config/.scripts/Wlogout.sh",
    "on-click-right": "~/.config/.scripts/ChangeBlur.sh",
    "interval": 86400,
    "tooltip": true
  },
  "group/traym": {
    "orientation": "horizontal",
    "drawer": {},
    "modules": [
      "custom/trayicon",
      "tray"
    ]
  },
  "group/power": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": "500",
      "transition-left-to-right": "true",
      "children-class": "drawer-child"
      //"click-to-reveal": "false"
    },
    "modules": [
      "battery",
      "backlight"
    ]
  },
  "group/motherboard": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature",
      "disk"
    ]
  },
  "group/laptop": {
    "orientation": "horizontal",
    "modules": [
      "backlight",
      "battery"
    ]
  },
  "group/audio": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "pulseaudio#microphone"
    ]
  },
  "group/appo#leg": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/launcher",
      "custom/chatgpt",
      "custom/browser",
      "custom/filemanager",
      "custom/lefty",
      "wlr/taskbar",
      "custom/righty"
    ]
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
