      "chromium": "ΎΚρ",
      "firefox": "ΎΚσ",
      "brave": "Όα╝",
      "qutebrowser": "ΎΑ╜",
      "mpv": "≤░Ρ╣",
      "spotify": "ΎΗ╝",
      "spotube": "≤░ΟΗ ",
      "vlc": "≤░Χ╝"
