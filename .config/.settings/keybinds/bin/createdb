CREATE TABLE "args" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"text"	TEXT NOT NULL UNIQUE,
	"desc"	TEXT,
	"varname"	INTEGER,
	PRIMARY KEY("ID" AUTOINCREMENT),
	FOREIGN KEY("varname") REFERENCES "vars"("ID")
);
CREATE TABLE "command" (
	"DISP_ID"	INTEGER NOT NULL,
	"ARG_ID"	INTEGER NOT NULL,
	PRIMARY KEY("DISP_ID","ARG_ID"),
	UNIQUE("DISP_ID","ARG_ID"),
	FOREIGN KEY("ARG_ID") REFERENCES "args"("ID"),
	FOREIGN KEY("DISP_ID") REFERENCES "dispatchers"("ID")
);
CREATE TABLE "context" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"name"	TEXT NOT NULL UNIQUE,
	PRIMARY KEY("ID" AUTOINCREMENT)
);
CREATE TABLE "dispatchers" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"text"	TEXT UNIQUE,
	"desc"	TEXT,
	PRIMARY KEY("ID" AUTOINCREMENT)
);
CREATE TABLE "files" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"loc"	TEXT UNIQUE,
	"desc"	TEXT,
	"varname"	INTEGER,
	PRIMARY KEY("ID" AUTOINCREMENT),
	FOREIGN KEY("varname") REFERENCES ""
);
CREATE TABLE "keybind_tags" (
	"KEY_ID"	INTEGER NOT NULL,
	"TAG_ID"	INTEGER NOT NULL,
	PRIMARY KEY("KEY_ID","TAG_ID"),
	FOREIGN KEY("KEY_ID") REFERENCES "keybinds"("ID"),
	FOREIGN KEY("TAG_ID") REFERENCES "tags"("ID")
);
CREATE TABLE "keybinds" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"locked"	INTEGER DEFAULT 0 CHECK(1),
	"mouse"	INTEGER DEFAULT 0 CHECK(1),
	"release"	INTEGER DEFAULT 0 CHECK(1),
	"repeat"	INTEGER DEFAULT 0 CHECK(1),
	"longPress"	INTEGER DEFAULT 0 CHECK(1),
	"non_consuming"	INTEGER DEFAULT 0 CHECK(1),
	"has_description"	INTEGER DEFAULT 0 CHECK(1),
	"modmask"	TEXT,
	"submask"	TEXT,
	"submask_universal"	INTEGER DEFAULT 0 CHECK(1),
	"key"	TEXT,
	"keycode"	TEXT,
	"catch_all"	INTEGER DEFAULT 0 CHECK(1),
	"command_ID"	INTEGER,
	"context_ID"	INTEGER,
	PRIMARY KEY("ID" AUTOINCREMENT),
	FOREIGN KEY("command_ID") REFERENCES "command",
	FOREIGN KEY("context_ID") REFERENCES "context"("ID")
);
CREATE TABLE "tags" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"name"	TEXT NOT NULL UNIQUE,
	PRIMARY KEY("ID" AUTOINCREMENT)
);
CREATE TABLE "vars" (
	"ID"	INTEGER NOT NULL UNIQUE,
	"type"	TEXT NOT NULL DEFAULT 'arg',
	"text"	TEXT NOT NULL,
	"desc"	TEXT NOT NULL,
	PRIMARY KEY("ID" AUTOINCREMENT)
);
