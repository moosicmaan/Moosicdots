# Colors (non-printing wrapped)
BRACKET_COLOR="\[\e[38;5;41m\]"
CLOCK_COLOR="\[\e[38;5;33m\]"
JOB_COLOR="\[\e[38;5;33m\]"
PATH_COLOR="\[\e[38;5;33m\]"
LINE_COLOR="\[\e[1;0m\]"
CLEAR_COLOR="\[\e[1;0m\]"
HL_COLOR="\[\e[1;53m\]"

# Unicode
LINE_STRAIGHT="─"
LINE_UPPER_CORNER="┌"
LINE_LOWER_CORNER="└"

PS1=" \
$LINE_COLOR$LINE_UPPER_CORNER$LINE_STRAIGHT\
$BRACKET_COLOR[$CLOCK_COLOR\t$LINE_COLOR$LINE_STRAIGHT$JOB_COLOR\$?$BRACKET_COLOR]\
$LINE_COLOR$LINE_STRAIGHT\
$BRACKET_COLOR[$JOB_COLOR\H$LINE_COLOR:$JOB_COLOR\w$BRACKET_COLOR]\
$LINE_COLOR$LINE_STRAIGHT\
$BRACKET_COLOR[$JOB_COLOR\j$BRACKET_COLOR]\
$LINE_COLOR$LINE_STRAIGHT\
$BRACKET_COLOR[$HL_COLOR!$LINE_COLOR:$JOB_COLOR\!$BRACKET_COLOR, $HL_COLOR#$LINE_COLOR:$JOB_COLOR\#$BRACKET_COLOR]\
\n \
$LINE_COLOR$LINE_LOWER_CORNER$LINE_STRAIGHT$JOB_COLOR\$ $CLEAR_COLOR"
